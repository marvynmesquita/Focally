{
    "rules": {
        ".read": false,
        ".write": false,
        "sessions": {
            "$sessionCode": {
                ".read": true,
                ".write": true,
                "createdAt": {
                    ".validate": "newData.isNumber()"
                },
                "offers": {
                    "$studentId": {
                        ".validate": "newData.isString()"
                    }
                },
                "answers": {
                    "$studentId": {
                        ".validate": "newData.isString()"
                    }
                }
            }
        }
    }
}